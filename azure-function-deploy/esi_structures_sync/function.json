{
    "bindings": [
        {
            "name": "myTimer",
            "type": "timerTrigger",
            "direction": "in",
            "schedule": "0 0 3 * * 0"
        },
        {
            "authLevel": "function",
            "type": "httpTrigger",
            "direction": "in",
            "name": "req",
            "methods": [
                "get",
                "post"
            ],
            "route": "sync/structures"
        },
        {
            "type": "http",
            "direction": "out",
            "name": "res"
        }
    ]
}